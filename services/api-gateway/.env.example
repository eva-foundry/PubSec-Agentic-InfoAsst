# AIA API Gateway — Environment Variables
# Copy to .env and fill in values.
# All prefixed with EVA_ (pydantic-settings reads EVA_<NAME>).

# --- Feature toggle ---
# true  = in-memory stores + mock embeddings (no Azure needed)
# false = real Azure services (Cosmos DB, AI Search, OpenAI, Blob)
EVA_API_MOCK=true

# --- Azure OpenAI ---
EVA_AZURE_OPENAI_ENDPOINT=https://msub-aia-dev-openai.openai.azure.com/
EVA_AZURE_OPENAI_API_KEY=
EVA_AZURE_OPENAI_DEPLOYMENT=chat-default
EVA_AZURE_OPENAI_API_VERSION=2024-12-01-preview
EVA_AZURE_OPENAI_EMBEDDING_DEPLOYMENT=embeddings-default

# --- Azure AI Search ---
EVA_AZURE_SEARCH_ENDPOINT=https://msub-aia-dev-search.search.windows.net
EVA_AZURE_SEARCH_API_KEY=
EVA_AZURE_SEARCH_INDEX_PREFIX=aia-workspace

# --- Cosmos DB ---
EVA_COSMOS_ENDPOINT=https://msub-sandbox-cosmos-free.documents.azure.com:443/
EVA_COSMOS_KEY=
EVA_COSMOS_DATABASE_WORKSPACES=aia-workspaces
EVA_COSMOS_DATABASE_PLATFORM=aia-platform
EVA_COSMOS_DATABASE_STATUS=statusdb

# --- Azure Blob Storage ---
EVA_AZURE_STORAGE_CONNECTION_STRING=

# --- APIM ---
EVA_APIM_GATEWAY_URL=

# --- Auth ---
EVA_AUTH_MODE=demo
EVA_ENTRA_TENANT_ID=
EVA_ENTRA_CLIENT_ID=
EVA_ENTRA_AUTHORITY=
EVA_ENTRA_GROUP_ADMIN=
EVA_ENTRA_GROUP_CONTRIBUTOR=
EVA_ENTRA_GROUP_READER=
EVA_ENTRA_GROUP_OPS=

# --- Azure Content Safety ---
EVA_CONTENT_SAFETY_ENDPOINT=
EVA_CONTENT_SAFETY_KEY=

# --- Observability ---
EVA_APPINSIGHTS_CONNECTION_STRING=

# --- Debug ---
EVA_DEBUG=true
