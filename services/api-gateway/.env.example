# Azure OpenAI (required for real LLM calls, falls back to mock if empty)
EVA_AZURE_OPENAI_ENDPOINT=https://msub-eva-dev-openai.openai.azure.com/
EVA_AZURE_OPENAI_API_KEY=your-api-key
EVA_AZURE_OPENAI_DEPLOYMENT=chat-default
EVA_AZURE_OPENAI_API_VERSION=2024-12-01-preview
EVA_AZURE_OPENAI_EMBEDDING_DEPLOYMENT=embeddings-default

# Auth mode (demo = proforma login, production = Entra ID)
EVA_AUTH_MODE=demo

# Debug mode (enables circuit breaker debug endpoints)
EVA_DEBUG=true
